{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xyn.local/schemas/policy_bundle_v0.schema.json",
  "title": "Xyn Policy Bundle v0",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_id",
    "app_slug",
    "workspace_id",
    "title",
    "scope",
    "ownership",
    "policy_families",
    "policies",
    "configurable_parameters",
    "explanation"
  ],
  "properties": {
    "schema_version": {
      "const": "xyn.policy_bundle.v0"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "app_slug": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "required": ["artifact_slug", "applies_to"],
      "properties": {
        "artifact_slug": {"type": "string"},
        "applies_to": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "ownership": {
      "type": "object",
      "required": ["owner_kind", "editable", "source"],
      "properties": {
        "owner_kind": {"type": "string"},
        "editable": {"type": "boolean"},
        "source": {"type": "string"}
      }
    },
    "policy_families": {
      "type": "array",
      "items": {"type": "string"}
    },
    "policies": {
      "type": "object",
      "required": [
        "validation_policies",
        "relation_constraints",
        "transition_policies",
        "invariant_policies",
        "derived_policies",
        "trigger_policies"
      ],
      "properties": {
        "validation_policies": {
          "type": "array",
          "items": {"type": "object"}
        },
        "relation_constraints": {
          "type": "array",
          "items": {"type": "object"}
        },
        "transition_policies": {
          "type": "array",
          "items": {"type": "object"}
        },
        "invariant_policies": {
          "type": "array",
          "items": {"type": "object"}
        },
        "derived_policies": {
          "type": "array",
          "items": {"type": "object"}
        },
        "trigger_policies": {
          "type": "array",
          "items": {"type": "object"}
        }
      }
    },
    "configurable_parameters": {
      "type": "array",
      "items": {"type": "object"}
    },
    "explanation": {
      "type": "object",
      "required": ["summary", "coverage", "future_capabilities"],
      "properties": {
        "summary": {"type": "string"},
        "coverage": {"type": "object"},
        "future_capabilities": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
