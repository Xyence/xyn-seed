# Xyn Seed v0.0 Configuration Template
# Copy this file to .env and fill in the required values

# Canonical runtime environment
XYN_ENV=local
XYN_BASE_DOMAIN=
XYN_AUTH_MODE=simple
XYN_INTERNAL_TOKEN=

# OIDC (required only when XYN_AUTH_MODE=oidc)
XYN_OIDC_ISSUER=
XYN_OIDC_CLIENT_ID=
XYN_OIDC_REDIRECT_URI=

# AI configuration
# Leave blank to infer from exactly one supplied API key.
XYN_AI_PROVIDER=
XYN_AI_MODEL=gpt-5-mini
XYN_AI_DISABLED=false

# AI Provider Keys (set exactly one for auto-inference, or set XYN_AI_PROVIDER explicitly)
XYN_OPENAI_API_KEY=
XYN_GEMINI_API_KEY=
XYN_ANTHROPIC_API_KEY=
XYN_SECRET_KEY=

# Database (defaults work with compose.yml)
DATABASE_URL=postgresql://xyn:xyn_dev_password@localhost:5432/xyn

# Redis (defaults work with compose.yml)
REDIS_URL=redis://localhost:6379/0

# Artifact Storage
ARTIFACT_STORE_PATH=./artifacts

# Logging
LOG_LEVEL=INFO

# Seed Kernel Artifact Loading
XYN_SEED_ENABLE_LEGACY_PRODUCT=false
XYN_ENABLE_BLUEPRINTS_LEGACY=false
# Canonical upstream base URL for both binding fetches and xyn-api proxy role.
XYN_API_BASE_URL=http://localhost:8000
XYN_KERNEL_WORKSPACE_ID=
XYN_KERNEL_MANIFEST_ROOTS=/home/ubuntu/src

# Traefik ingress defaults
XYN_TRAEFIK_NETWORK=xyn_traefik
XYN_SEED_HOST=seed.localhost
XYN_SEED_URL=http://seed.localhost
XYN_TRAEFIK_WEB_PORT=80
XYN_TRAEFIK_WEBSECURE_PORT=443
XYN_TRAEFIK_DASHBOARD=false
XYN_TRAEFIK_ENABLE_TLS=false
XYN_TRAEFIK_CERT_RESOLVER=letsencrypt
XYN_TRAEFIK_ACME_EMAIL=
XYN_TRAEFIK_ACME_CHALLENGE=http
XYN_TRAEFIK_DNS_PROVIDER=route53

# Optional sibling route host overrides
XYN_LOCAL_UI_HOST=
XYN_LOCAL_API_HOST=

# Legacy compatibility aliases (deprecated; prefer XYN_* above)
# DOMAIN -> XYN_BASE_DOMAIN
# XYENCE_INTERNAL_TOKEN -> XYN_INTERNAL_TOKEN
