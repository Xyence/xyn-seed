class Colors:
    RED = "\033[91m"
    GREEN = "\033[92m"
    YELLOW = "\033[93m"
    BLUE = "\033[94m"
    END = "\033[0m"


def print_error(msg: str) -> None:
    print(f"{Colors.RED}✗ {msg}{Colors.END}")


def print_success(msg: str) -> None:
    print(f"{Colors.GREEN}✓ {msg}{Colors.END}")


def print_warning(msg: str) -> None:
    print(f"{Colors.YELLOW}⚠ {msg}{Colors.END}")


def print_info(msg: str) -> None:
    print(f"{Colors.BLUE}ℹ {msg}{Colors.END}")


AI_KEY_SPECS = {
    "openai": ("XYN_OPENAI_API_KEY", "OPENAI_API_KEY"),
    "gemini": ("XYN_GEMINI_API_KEY", "GEMINI_API_KEY", "GOOGLE_API_KEY"),
    "anthropic": ("XYN_ANTHROPIC_API_KEY", "ANTHROPIC_API_KEY"),
}
DEFAULT_ARTIFACT_REGISTRY = "public.ecr.aws/i0h0h0n4/xyn/artifacts"
DEFAULT_UI_IMAGE_NAME = "xyn-ui"
DEFAULT_API_IMAGE_NAME = "xyn-api"
DEFAULT_IMAGE_TAG = "dev"
DEFAULT_CONTEXT_PACK_MANIFEST = ".xyn/sync/context-packs.manifest.json"


def _as_bool(value: str) -> bool:
    return str(value or "").strip().lower() in {"1", "true", "yes", "on"}


def _build_default_seed_url(runtime: dict[str, str]) -> str:
    scheme = "https" if _as_bool(runtime.get("XYN_TRAEFIK_ENABLE_TLS", "false")) else "http"
    host = str(runtime.get("XYN_SEED_HOST", "seed.localhost")).strip() or "seed.localhost"
    if scheme == "https":
        raw_port = str(runtime.get("XYN_TRAEFIK_WEBSECURE_PORT", "443")).strip() or "443"
        default_port = "443"
    else:
        raw_port = str(runtime.get("XYN_TRAEFIK_WEB_PORT", "80")).strip() or "80"
        default_port = "80"
    if raw_port == default_port:
        return f"{scheme}://{host}"
    return f"{scheme}://{host}:{raw_port}"


def _parse_args(argv: list[str]) -> dict[str, Any]:
    command = argv[1] if len(argv) > 1 and not argv[1].startswith("-") else ""
    values: dict[str, Any] = {
        "command": command,
        "non_interactive": "--non-interactive" in argv,
        "skip_ai_keys": "--skip-ai-keys" in argv,
        "provision": "--provision" in argv,
        "force": "--force" in argv,
        "name": None,
        "job_prompt": None,
        "repo_ref": None,
        "seed_url": None,
        "attach": "--attach" in argv,
    }
    for idx, token in enumerate(argv):
        if token in {"--name", "--job-prompt", "--repo-ref", "--seed-url"}:
            if idx + 1 < len(argv):
                key = token.replace("--", "").replace("-", "_")
                values[key] = argv[idx + 1]
    return values


def check_env_file() -> bool:
    env_file = Path(".env")
    template_candidates = [Path(".env.example"), Path(".env.template")]
    template = next((candidate for candidate in template_candidates if candidate.exists()), None)
    if env_file.exists():
        _ensure_env_defaults_file()
        return True
    if not template:
        print_error(".env.example/.env.template not found")
        return False
    print_warning(".env not found")
    print_info(f"Creating .env from {template.name} ...")
    env_file.write_text(template.read_text(encoding="utf-8"), encoding="utf-8")
    _ensure_env_defaults_file()
    print_success("Created .env. Add one AI key (e.g., XYN_OPENAI_API_KEY) and re-run.")
    return True


def load_env() -> dict[str, str]:
    env_file = Path(".env")
    env_vars: dict[str, str] = {}
    if not env_file.exists():
        return env_vars
    for raw in env_file.read_text(encoding="utf-8").splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        env_vars[key.strip()] = value.strip()
    return env_vars


def _artifact_defaults(env_vars: dict[str, str]) -> dict[str, str]:
    normalized = dict(env_vars)
    registry = str(normalized.get("XYN_ARTIFACT_REGISTRY", "")).strip() or DEFAULT_ARTIFACT_REGISTRY
    normalized["XYN_ARTIFACT_REGISTRY"] = registry
    normalized.setdefault("XYN_UI_IMAGE", f"{registry}/{DEFAULT_UI_IMAGE_NAME}:{DEFAULT_IMAGE_TAG}")
    normalized.setdefault("XYN_API_IMAGE", f"{registry}/{DEFAULT_API_IMAGE_NAME}:{DEFAULT_IMAGE_TAG}")
    return normalized


def _ensure_env_defaults_file() -> None:
    env_path = Path(".env")
    if not env_path.exists():
        return
    existing = load_env()
    desired = _artifact_defaults(existing)
    lines = env_path.read_text(encoding="utf-8").splitlines()
    appended = False
    for key in ("XYN_ARTIFACT_REGISTRY", "XYN_UI_IMAGE", "XYN_API_IMAGE"):
        if str(existing.get(key, "")).strip():
            continue
        lines.append(f"{key}={desired[key]}")
        appended = True
    if appended:
        env_path.write_text("\n".join(lines).rstrip() + "\n", encoding="utf-8")
        print_success("Added default artifact registry/image settings to .env")


def normalize_ai_env(env_vars: dict[str, str]) -> dict[str, str]:
    normalized = _artifact_defaults(env_vars)
    for provider, names in AI_KEY_SPECS.items():
        canonical = names[0]
        first = ""
        for name in names:
            value = str(normalized.get(name, "")).strip()
            if value:
                first = value
                break
        if first:
            for name in names:
                if not str(normalized.get(name, "")).strip():
                    normalized[name] = first
            normalized[canonical] = first

    ai_disabled = _as_bool(normalized.get("XYN_AI_DISABLED", "false"))
    if ai_disabled:
        normalized.setdefault("XYN_AI_PROVIDER", "none")
    else:
        if not str(normalized.get("XYN_AI_PROVIDER", "")).strip():
            if str(normalized.get("XYN_OPENAI_API_KEY", "")).strip():
                normalized["XYN_AI_PROVIDER"] = "openai"
            elif str(normalized.get("XYN_GEMINI_API_KEY", "")).strip():
                normalized["XYN_AI_PROVIDER"] = "gemini"
            elif str(normalized.get("XYN_ANTHROPIC_API_KEY", "")).strip():
                normalized["XYN_AI_PROVIDER"] = "anthropic"
    return normalized


def check_api_keys(skip_ai_keys: bool) -> bool:
    if skip_ai_keys:
        print_warning("Skipping AI key validation (--skip-ai-keys)")
        return True
    env_vars = normalize_ai_env(load_env())
    ai_disabled = _as_bool(env_vars.get("XYN_AI_DISABLED", "false"))
    if ai_disabled:
        print_warning("AI explicitly disabled (XYN_AI_DISABLED=true)")
        return True

    present = [
        key for key in ("XYN_OPENAI_API_KEY", "XYN_GEMINI_API_KEY", "XYN_ANTHROPIC_API_KEY") if str(env_vars.get(key, "")).strip()
    ]
    if not present:
        print_error("No AI provider key configured.")
        print_info("Set one of the following in .env:")
        print_info("  - XYN_OPENAI_API_KEY=...")
        print_info("  - XYN_GEMINI_API_KEY=...")
        print_info("  - XYN_ANTHROPIC_API_KEY=...")
        print_info("Or explicitly disable AI:")
        print_info("  - XYN_AI_DISABLED=true")
        return False
    for key in present:
        print_success(f"{key} configured")
    return True


def check_docker() -> bool:
    try:
        result = subprocess.run(["docker", "ps"], capture_output=True, text=True, check=False)
    except FileNotFoundError:
        print_error("Docker command not found")
        return False
    if result.returncode != 0:
        print_error("Docker is not running or not accessible")
        return False
    print_success("Docker is running")
    return True


def check_docker_compose() -> bool:
    try:
        result = subprocess.run(["docker", "compose", "version"], capture_output=True, text=True, check=False)
    except FileNotFoundError:
        print_error("Docker Compose not found")
        return False
    if result.returncode != 0:
        print_error("Docker Compose is not available")
        return False
    print_success("Docker Compose is available")
    return True


def create_artifacts_dir() -> bool:
    roots = [
        Path(".xyn/artifacts"),
        Path(".xyn/workspace"),
        Path(".xyn/deployments"),
        Path(".xyn/sync"),
    ]
    legacy_roots = [Path("artifacts"), Path("workspace")]
    created = False
    for path in roots:
        if not path.exists():
            path.mkdir(parents=True)
            created = True
    legacy_present = [str(path) for path in legacy_roots if path.exists()]
    if created:
        print_success("Created local Xyn runtime directories under .xyn/")
    if legacy_present:
        print_warning(
            "Legacy repo-root runtime directories detected: "
            + ", ".join(legacy_present)
            + ". They are no longer used as canonical runtime storage."
        )
    return True


def _find_xyn_platform_root() -> Optional[Path]:
    override = str(os.getenv("XYN_PLATFORM_ROOT", "")).strip()
    if override:
        path = Path(override).expanduser().resolve()
        if path.exists():
            return path
    sibling = Path.cwd().resolve().parent / "xyn-platform"
    if sibling.exists():
        return sibling
    return None


def sync_context_pack_manifest() -> bool:
    output_path = Path(DEFAULT_CONTEXT_PACK_MANIFEST)
    output_path.parent.mkdir(parents=True, exist_ok=True)
    platform_root = _find_xyn_platform_root()
    if platform_root is None:
        if output_path.exists():
            print_warning("xyn-platform repo not found; using existing synced context-pack manifest")
        else:
            print_warning("xyn-platform repo not found; xyn-core will fall back to builtin context-pack definitions")
        return True
    script_path = platform_root / "services" / "xyn-api" / "backend" / "scripts" / "export_core_context_packs.py"
    if not script_path.exists():
        if output_path.exists():
            print_warning("Context-pack export script not found in xyn-platform; using existing synced manifest")
        else:
            print_warning("Context-pack export script not found in xyn-platform; xyn-core will fall back to builtin context-pack definitions")
        return True
    result = subprocess.run(
        [sys.executable, str(script_path), "--output", str(output_path.resolve())],
        check=False,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print_warning("Context-pack manifest sync failed; xyn-core may use fallback definitions")
        if result.stderr.strip():
            print_warning(result.stderr.strip())
        return True
    print_success(f"Synchronized context-pack manifest from xyn-platform to {output_path}")
    return True


def build_runtime_env() -> dict[str, str]:
    runtime = dict(os.environ)
    env_vars = normalize_ai_env(load_env())
    runtime.update(env_vars)
    if not str(runtime.get("XYN_HOST_SRC_ROOT", "")).strip():
        runtime["XYN_HOST_SRC_ROOT"] = str(Path.cwd().resolve().parent)
    runtime.setdefault("XYN_TRAEFIK_NETWORK", "xyn_traefik")
    runtime.setdefault("XYN_SEED_HOST", "seed.localhost")
    runtime.setdefault("XYN_AUTH_MODE", "dev")
    runtime.setdefault("XYN_PUBLIC_BASE_URL", "http://localhost")
    runtime.setdefault("XYN_TRUST_PROXY", "true")
    runtime.setdefault("XYN_CONTEXT_PACK_MANIFEST_PATH", "/app/.xyn/sync/context-packs.manifest.json")
    if not str(runtime.get("XYN_SEED_URL", "")).strip():
        runtime["XYN_SEED_URL"] = _build_default_seed_url(runtime)
    if str(runtime.get("XYN_AUTH_MODE", "")).strip().lower() == "token":
        if not str(runtime.get("XYN_UI_BEARER_TOKEN", "")).strip():
            runtime["XYN_UI_BEARER_TOKEN"] = "xyn-local-bootstrap-token"
    if not str(runtime.get("DOCKER_GID", "")).strip():
        sock = Path("/var/run/docker.sock")
        if sock.exists():
            try:
                runtime["DOCKER_GID"] = str(sock.stat().st_gid)
            except OSError:
                pass
    return runtime


def preflight(skip_ai_keys: bool) -> bool:
    print_info("Running Xyn Seed preflight checks...\n")
    checks = [
        ("Environment file", check_env_file),
        ("AI keys", lambda: check_api_keys(skip_ai_keys)),
        ("Docker", check_docker),
        ("Docker Compose", check_docker_compose),
        ("Artifacts directory", create_artifacts_dir),
        ("Context-pack manifest sync", sync_context_pack_manifest),
    ]
    all_passed = True
    for _, fn in checks:
        if not fn():
            all_passed = False
    print()
    if not all_passed:
        print_error("Preflight checks failed")
        return False
    print_success("All preflight checks passed")
    return True


def _compose_up(detached: bool, env: dict[str, str]) -> bool:
    args = ["docker", "compose", "up", "--build"]
    if detached:
        args.append("-d")
    proc = subprocess.run(
        args,
        check=False,
        env=env,
        capture_output=detached,
        text=detached,
    )
    if proc.returncode == 0:
        return True
    print_error(f"Failed to start platform: Command '{' '.join(args)}' exited {proc.returncode}")
    if detached and proc.stderr and proc.stderr.strip():
        print_error(proc.stderr.strip())
    return False


def _run_compose_sql(env: dict[str, str], sql: str) -> tuple[int, str, str]:
    cmd = [
        "docker",
        "compose",
        "exec",
        "-T",
        "postgres",
        "psql",
        "-U",
        "xyn",
        "-d",
        "xyn",
        "-t",
        "-A",
        "-c",
        sql,
    ]
    proc = subprocess.run(cmd, check=False, capture_output=True, text=True, env=env)
    return proc.returncode, proc.stdout, proc.stderr


def _ensure_postgis_ready(env: dict[str, str], *, timeout_seconds: int = 60) -> bool:
    print_info("Ensuring PostGIS is available in local runtime database...")
    deadline = time.time() + timeout_seconds
    while time.time() < deadline:
        code, stdout, _stderr = _run_compose_sql(
            env,
            "SELECT EXISTS (SELECT 1 FROM pg_available_extensions WHERE name='postgis');",
        )
        if code == 0:
            available = str(stdout or "").strip().lower() in {"t", "true", "1"}
            if not available:
                print_error(
                    "PostGIS extension is not available in the postgres container. "
                    "Use a PostGIS-capable DB image (for example postgis/postgis:16-3.4)."
                )
                return False
            break
        time.sleep(2)
    else:
        print_error("Unable to reach postgres container to verify PostGIS availability.")
        return False

    code, _stdout, stderr = _run_compose_sql(env, "CREATE EXTENSION IF NOT EXISTS postgis;")
    if code != 0:
        print_error("Failed to enable PostGIS extension in database 'xyn'.")
        if stderr.strip():
            print_error(stderr.strip())
        return False

    code, stdout, stderr = _run_compose_sql(
        env,
        "SELECT postgis_full_version();",
    )
    if code != 0:
        print_error("PostGIS extension appears unavailable after enablement attempt.")
        if stderr.strip():
            print_error(stderr.strip())
        return False
    version_text = str(stdout or "").strip()
    if not version_text:
        print_error("PostGIS version output was empty; database may be misconfigured.")
        return False

    code, stdout, stderr = _run_compose_sql(
        env,
        "SELECT ST_AsText(ST_SetSRID(ST_MakePoint(0,0),4326));",
    )
    if code != 0:
        print_error("PostGIS sanity query failed (`ST_AsText(ST_SetSRID(ST_MakePoint(0,0),4326))`).")
        if stderr.strip():
            print_error(stderr.strip())
        return False
    if "POINT(0 0)" not in str(stdout or "").strip():
        print_error("PostGIS sanity query returned unexpected result.")
        return False

    print_success("PostGIS is enabled and spatial SQL is callable.")
    return True


def _seed_health_candidates(seed_url: str) -> list[tuple[str, dict[str, str]]]:
    parsed = urlparse(seed_url)
    scheme = parsed.scheme or "http"
    host = parsed.hostname or "seed.localhost"
    port = parsed.port
    netloc = host if port is None else f"{host}:{port}"
    base_paths = ["/health", "/api/v1/health"]
    candidates: list[tuple[str, dict[str, str]]] = []
    seen: set[tuple[str, str, str]] = set()

    def _add_candidate(target_host: str, headers: dict[str, str]) -> None:
        candidate_netloc = target_host if port is None else f"{target_host}:{port}"
        for path in base_paths:
            key = (scheme, candidate_netloc, path)
            if key in seen:
                continue
            seen.add(key)
            url = urlunparse((scheme, candidate_netloc, path, "", "", ""))
            candidates.append((url, headers))

    _add_candidate(host, {})
    if host.endswith(".localhost"):
        host_header = netloc
        _add_candidate("localhost", {"Host": host_header})
        _add_candidate("127.0.0.1", {"Host": host_header})
    return candidates


def _wait_for_seed_health(seed_url: str, timeout_seconds: int = 120, show_progress: bool = False) -> bool:
    deadline = time.time() + timeout_seconds
    candidates = _seed_health_candidates(seed_url)
    next_progress_at = time.time() + 10
    started_at = time.time()
    while time.time() < deadline:
        for health_url, headers in candidates:
            try:
                req = Request(health_url, method="GET", headers=headers)
                with urlopen(req, timeout=5) as response:
                    if response.status == 200:
                        return True
            except Exception:
                continue
        if show_progress and time.time() >= next_progress_at:
            elapsed = int(time.time() - started_at)
            print_info(f"Still waiting for seed API health ({elapsed}s elapsed)...")
            next_progress_at = time.time() + 10
        time.sleep(2)
    return False


def _print_seed_health_debug(seed_url: str) -> None:
    print_warning("Seed health check timed out. Debug info:")
    print_warning("  - docker compose ps")
    subprocess.run(["docker", "compose", "ps"], check=False)
    print_warning("  - last 80 lines from xyn-core logs")
    subprocess.run(["docker", "compose", "logs", "--tail", "80", "core"], check=False)
    if seed_url.strip():
        print_warning(f"  - health candidates from seed_url={seed_url}")
        for candidate_url, headers in _seed_health_candidates(seed_url):
            if headers:
                print_warning(f"    * {candidate_url} (headers: {headers})")
            else:
                print_warning(f"    * {candidate_url}")


def _docker_image_exists(image_ref: str) -> bool:
    code, _, _ = _run_capture(["docker", "image", "inspect", image_ref])
    return code == 0


def _context_has_dockerfile(path_text: str) -> bool:
    candidate = Path(path_text).expanduser().resolve()
    return candidate.is_dir() and (candidate / "Dockerfile").exists()


def _print_pull_error(image_ref: str) -> None:
    print_error("Unable to pull artifact image:")
    print_error(image_ref)
    print()
    print_info("Possible fixes:")
    print_info("  - Verify network access")
    print_info("  - Override XYN_ARTIFACT_REGISTRY in .env")
    print_info("  - Provide local build contexts:")
    print_info("      XYN_LOCAL_API_CONTEXT")
    print_info("      XYN_LOCAL_UI_CONTEXT")


def _resolve_artifacts(env: dict[str, str]) -> tuple[bool, dict[str, str]]:
    resolved = {
        "registry": str(env.get("XYN_ARTIFACT_REGISTRY", "")).strip() or DEFAULT_ARTIFACT_REGISTRY,
        "ui_image": str(env.get("XYN_UI_IMAGE", "")).strip(),
        "api_image": str(env.get("XYN_API_IMAGE", "")).strip(),
        "mode": "artifact_pull",
    }
    if not resolved["ui_image"]:
        resolved["ui_image"] = f"{resolved['registry']}/{DEFAULT_UI_IMAGE_NAME}:{DEFAULT_IMAGE_TAG}"
    if not resolved["api_image"]:
        resolved["api_image"] = f"{resolved['registry']}/{DEFAULT_API_IMAGE_NAME}:{DEFAULT_IMAGE_TAG}"
    local_ui_context = str(env.get("XYN_LOCAL_UI_CONTEXT", "")).strip()
    local_api_context = str(env.get("XYN_LOCAL_API_CONTEXT", "")).strip()
    if local_ui_context and local_api_context and _context_has_dockerfile(local_ui_context) and _context_has_dockerfile(local_api_context):
        resolved["mode"] = "local_build"
        print_info(f"Building local API image from: {local_api_context}")
        code, _, err = _run_capture(["docker", "build", "-t", DEFAULT_API_IMAGE_NAME, local_api_context])
        if code != 0:
            print_error(err or "docker build failed for API context")
            return False, resolved
        print_info(f"Building local UI image from: {local_ui_context}")
        code, _, err = _run_capture(["docker", "build", "-t", DEFAULT_UI_IMAGE_NAME, local_ui_context])
        if code != 0:
            print_error(err or "docker build failed for UI context")
            return False, resolved
        resolved["api_image"] = DEFAULT_API_IMAGE_NAME
        resolved["ui_image"] = DEFAULT_UI_IMAGE_NAME
        return True, resolved

    force_pull = _as_bool(str(env.get("XYN_ARTIFACT_FORCE_PULL", "true")))
    for image_ref in (resolved["api_image"], resolved["ui_image"]):
        should_pull = force_pull or image_ref.endswith(":dev")
        if should_pull:
            print_info("Pulling artifact:")
            print(image_ref)
            code, _, _ = _run_capture(["docker", "pull", image_ref])
            if code != 0:
                if _docker_image_exists(image_ref):
                    print_warning(f"Pull failed for {image_ref}; falling back to cached local image")
                    continue
                _print_pull_error(image_ref)
                return False, resolved
            continue
        if _docker_image_exists(image_ref):
            print_info(f"Using cached artifact image {image_ref}")
            continue
        print_info("Pulling artifact:")
        print(image_ref)
        code, _, _ = _run_capture(["docker", "pull", image_ref])
        if code != 0:
            _print_pull_error(image_ref)
            return False, resolved
    return True, resolved


def _resolve_artifacts_via_seed(seed_url: str, env: dict[str, str]) -> tuple[bool, dict[str, Any]]:
    params: dict[str, str] = {
        "workspace_slug": str(env.get("XYN_WORKSPACE_SLUG", "default")).strip() or "default",
        "ensure_local": "true",
    }
    registry_slug = str(env.get("XYN_ARTIFACT_REGISTRY_SLUG", "")).strip()
    channel = str(env.get("XYN_ARTIFACT_CHANNEL", "")).strip()
    if registry_slug:
        params["registry_slug"] = registry_slug
    if channel:
        params["channel"] = channel
    url = f"{seed_url.rstrip('/')}/api/v1/artifact-registries/resolve?{urlencode(params)}"
    req = Request(url, method="GET")
    try:
        with urlopen(req, timeout=180) as response:
            payload = json.loads(response.read().decode("utf-8") or "{}")
        return True, payload
    except HTTPError as exc:
        body = exc.read().decode("utf-8", errors="ignore")
        return False, {"error": body or f"HTTP {exc.code}"}
    except URLError as exc:
        return False, {"error": str(exc)}


def _provision_local(
    seed_url: str,
    *,
    name: Optional[str],
    force: bool,
    job_prompt: Optional[str],
    repo_ref: Optional[str],
    ui_image: Optional[str],
    api_image: Optional[str],
    registry_slug: Optional[str],
    channel: Optional[str],
    workspace_slug: Optional[str],
) -> tuple[bool, dict[str, Any]]:
    payload: dict[str, Any] = {}
    if name:
        payload["name"] = name
    if force:
        payload["force"] = True
    if job_prompt:
        payload["job"] = {"prompt": job_prompt, "repo_ref": repo_ref or str(Path.cwd().resolve())}
    if ui_image:
        payload["ui_image"] = ui_image
    if api_image:
        payload["api_image"] = api_image
    if registry_slug:
        payload["registry_slug"] = registry_slug
    if channel:
        payload["channel"] = channel
    if workspace_slug:
        payload["workspace_slug"] = workspace_slug
    request = Request(
        f"{seed_url.rstrip('/')}/api/v1/provision/local-instance",
        method="POST",
        headers={"Content-Type": "application/json"},
        data=json.dumps(payload).encode("utf-8"),
    )
    try:
        with urlopen(request, timeout=180) as response:
            body = response.read().decode("utf-8")
        return True, json.loads(body or "{}")
    except HTTPError as exc:
        body = exc.read().decode("utf-8", errors="ignore")
        return False, {"error": body or f"HTTP {exc.code}"}
    except URLError as exc:
        return False, {"error": str(exc)}


def start(detached: bool, env: dict[str, str]) -> bool:
    print_info("Starting seed core stack...")
    if not _compose_up(detached=detached, env=env):
        return False
    if not _ensure_postgis_ready(env):
        return False
    seed_url = str(env.get("XYN_SEED_URL", "")).strip() or _build_default_seed_url(env)
    print_success("Seed core stack started")
    print_info(f"Seed URL: {seed_url}")
    print_info("Use this in browser (not plain http://localhost unless you mapped host rules that way).")
    return True


def start_with_provision(env: dict[str, str], *, force: bool, name: Optional[str], job_prompt: Optional[str], repo_ref: Optional[str], seed_url: str) -> int:
    if not start(detached=True, env=env):
        return 1
    print_info("Waiting for seed API health...")
    if not _wait_for_seed_health(seed_url, timeout_seconds=180, show_progress=True):
        print_error(f"Seed API did not become healthy at {seed_url}/health")
        _print_seed_health_debug(seed_url)
        return 2
    print_success("Seed API is healthy")
    print_info("Resolving artifacts...")
    artifacts_ok, resolved = _resolve_artifacts_via_seed(seed_url, env)
    if not artifacts_ok:
        print_warning(f"Seed registry resolver failed; falling back to local env resolution: {resolved.get('error')}")
        artifacts_ok, fallback = _resolve_artifacts(env)
        resolved = {
            "registry_slug": str(env.get("XYN_ARTIFACT_REGISTRY_SLUG", "")).strip() or "env-fallback",
            "registry": {"endpoint": fallback.get("registry"), "defaults": {"channel": DEFAULT_IMAGE_TAG}},
            "images": {
                "ui_image": fallback.get("ui_image"),
                "api_image": fallback.get("api_image"),
                "channel": DEFAULT_IMAGE_TAG,
            },
            "operations": [],
        }
    if not artifacts_ok:
        return 4
    registry = resolved.get("registry") if isinstance(resolved.get("registry"), dict) else {}
    images = resolved.get("images") if isinstance(resolved.get("images"), dict) else {}
    endpoint = str(registry.get("endpoint") or "").strip()
    reg_slug = str(resolved.get("registry_slug") or "default-registry").strip() or "default-registry"
    eff_channel = str(images.get("channel") or DEFAULT_IMAGE_TAG).strip() or DEFAULT_IMAGE_TAG
    print_info(f"Using ArtifactRegistry: {reg_slug} ({endpoint}) channel={eff_channel}")
    for op in list(resolved.get("operations") or []):
        op_text = str(op or "").strip()
        if op_text.startswith("Pulled artifact image "):
            image_ref = op_text.replace("Pulled artifact image ", "", 1)
            print_info("Pulling artifact:")
            print(image_ref)
        elif op_text.startswith("Using cached artifact image "):
            print_info(op_text)
        elif op_text:
            print_info(op_text)
    print_info("Provisioning local instance...")
    ok, payload = _provision_local(
        seed_url,
        name=name,
        force=force,
        job_prompt=job_prompt,
        repo_ref=repo_ref,
        ui_image=str(images.get("ui_image") or ""),
        api_image=str(images.get("api_image") or ""),
        registry_slug=reg_slug,
        channel=eff_channel,
        workspace_slug=str(env.get("XYN_WORKSPACE_SLUG", "default")).strip() or "default",
    )
    if not ok:
        print_error(f"Provisioning failed: {payload.get('error')}")
        return 3
    ui_url = str(payload.get("ui_url") or "").strip()
    api_url = str(payload.get("api_url") or "").strip()
    status = str(payload.get("status") or "unknown")
    print_success(f"Provision status: {status}")
    if payload.get("ensured_artifacts"):
        print_info("Ensured artifacts:")
        for row in payload.get("ensured_artifacts") or []:
            print_info(f"  - {row.get('slug')}@{row.get('version')}")
    if api_url:
        print_info(f"API:  {api_url}")
    if ui_url:
        print_success(f"UI available at: {ui_url}")
    else:
        print_warning("Provisioning completed but no UI URL was returned")
    auth_mode = str(env.get("XYN_AUTH_MODE", "dev")).strip().lower()
    if auth_mode in {"simple", "local"}:
        auth_mode = "dev"
    print_info(f"Auth mode: {auth_mode}")
    if auth_mode == "token":
        token_value = str(env.get("XYN_UI_BEARER_TOKEN", "")).strip()
        if token_value:
            print_info(f"Bootstrap token: {token_value}")
    return 0


def _deployment_states() -> list[dict[str, Any]]:
    root = Path(".xyn/deployments")
    if not root.exists():
        return []
    rows: list[dict[str, Any]] = []
    for child in sorted(root.iterdir()):
        if not child.is_dir():
            continue
        state = child / "deployment_state.json"
        if not state.exists():
            continue
        try:
            rows.append(json.loads(state.read_text(encoding="utf-8")))
        except Exception:
            continue
    return rows


def _discover_provisioned_instances_from_docker() -> list[dict[str, Any]]:
    code, stdout, _ = _run_capture(
        ["docker", "ps", "-a", "--format", "{{.Names}}\t{{.Label \"com.docker.compose.project\"}}"]
    )
    if code != 0:
        return []
    projects: set[str] = set()
    for row in (stdout or "").splitlines():
        row = row.strip()
        if not row:
            continue
        parts = row.split("\t")
        project = parts[1].strip() if len(parts) > 1 else ""
        if not project.startswith("xyn-"):
            continue
        projects.add(project)

    discovered: list[dict[str, Any]] = []
    for project in sorted(projects):
        code_names, names_out, _ = _run_capture(
            ["docker", "ps", "-a", "--filter", f"label=com.docker.compose.project={project}", "--format", "{{.Names}}"]
        )
        if code_names != 0:
            continue
        names = [name.strip() for name in names_out.splitlines() if name.strip()]
        labels: dict[str, str] = {}
        for name in names:
            code_labels, labels_json, _ = _run_capture(["docker", "inspect", "--format", "{{json .Config.Labels}}", name])
            if code_labels != 0:
                continue
            try:
                raw_labels = json.loads(labels_json.strip() or "{}")
            except json.JSONDecodeError:
                continue
            for key, value in raw_labels.items():
                labels[str(key)] = str(value)

        ui_rule = next((str(v) for k, v in labels.items() if k.startswith("traefik.http.routers.") and k.endswith("-ui-http.rule")), "")
        api_rule = next((str(v) for k, v in labels.items() if k.startswith("traefik.http.routers.") and k.endswith("-api-http.rule")), "")
        host_match = re.search(r"Host\(`([^`]+)`\)", ui_rule or api_rule)
        api_host_match = re.search(r"Host\(`([^`]+)`\)", api_rule)
        ui_url = f"http://{host_match.group(1)}" if host_match else ""
        api_url = f"http://{api_host_match.group(1)}" if api_host_match else ""
        if api_url and ui_url and api_url == ui_url:
            api_url = f"{api_url}/xyn/api"
        discovered.append({"compose_project": project, "ui_url": ui_url, "api_url": api_url})
    return discovered


def _run_capture(cmd: list[str]) -> tuple[int, str, str]:
    try:
        proc = subprocess.run(cmd, check=False, capture_output=True, text=True)
        return proc.returncode, proc.stdout, proc.stderr
    except Exception as exc:
        return 1, "", str(exc)


def _cleanup_compose_project(project: str) -> tuple[bool, str]:
    project_name = str(project or "").strip()
    if not project_name:
        return False, "missing project name"

    ok = True
    notes: list[str] = []

    code, containers_out, containers_err = _run_capture(
        ["docker", "ps", "-a", "--filter", f"label=com.docker.compose.project={project_name}", "-q"]
    )
    if code != 0:
        return False, containers_err.strip() or f"failed to list containers for {project_name}"
    container_ids = [line.strip() for line in containers_out.splitlines() if line.strip()]
    if container_ids:
        code, _, err = _run_capture(["docker", "rm", "-f", *container_ids])
        if code != 0:
            ok = False
            notes.append(err.strip() or "failed to remove containers")

    code, networks_out, networks_err = _run_capture(
        ["docker", "network", "ls", "--filter", f"label=com.docker.compose.project={project_name}", "-q"]
    )
    if code != 0:
        ok = False
        notes.append(networks_err.strip() or "failed to list networks")
    else:
        network_ids = [line.strip() for line in networks_out.splitlines() if line.strip()]
        if network_ids:
            code, _, err = _run_capture(["docker", "network", "rm", *network_ids])
            if code != 0:
                ok = False
                notes.append(err.strip() or "failed to remove networks")

    code, volumes_out, volumes_err = _run_capture(
        ["docker", "volume", "ls", "--filter", f"label=com.docker.compose.project={project_name}", "-q"]
    )
    if code != 0:
        ok = False
        notes.append(volumes_err.strip() or "failed to list volumes")
    else:
        volume_ids = [line.strip() for line in volumes_out.splitlines() if line.strip()]
        if volume_ids:
            code, _, err = _run_capture(["docker", "volume", "rm", *volume_ids])
            if code != 0:
                ok = False
                notes.append(err.strip() or "failed to remove volumes")

    if ok:
        return True, ""
    return False, "; ".join(note for note in notes if note)


def _stop_provisioned_instances() -> tuple[list[str], list[str]]:
    stopped: list[str] = []
    failures: list[str] = []
    seen_projects: set[str] = set()

    state_rows = _deployment_states()
    discovered_rows = _discover_provisioned_instances_from_docker()
    candidates = [*state_rows, *discovered_rows]

    for row in candidates:
        project = str(row.get("compose_project") or "").strip()
        if not project or not project.startswith("xyn-") or project in seen_projects:
            continue
        seen_projects.add(project)
        ok, err = _cleanup_compose_project(project)
        if ok:
            stopped.append(project)
        else:
            failures.append(f"{project}: {err}")
    return stopped, failures


def status(seed_url: str) -> int:
    print_info("Seed status")
    if _wait_for_seed_health(seed_url, timeout_seconds=2):
        print_success(f"Seed API healthy: {seed_url}/health")
    else:
        print_warning(f"Seed API not healthy: {seed_url}/health")
    try:
        subprocess.run(["docker", "compose", "ps"], check=False)
    except Exception:
        pass
    states = _deployment_states()
    if not states:
        states = _discover_provisioned_instances_from_docker()
    if not states:
        print_warning("No provisioned local sibling instances found")
        return 0
    print_info("Provisioned sibling instances:")
    for row in states:
        print_info(f"  - {row.get('compose_project')} -> {row.get('ui_url')} (api {row.get('api_url')})")
    return 0


def apply_release_plan(path: str) -> int:
    plan_path = Path(path)
    if not plan_path.exists():
        print_error(f"Release plan not found: {path}")
        return 1
    try:
        plan = json.loads(plan_path.read_text())
    except json.JSONDecodeError as exc:
        print_error(f"Invalid release plan JSON: {exc}")
        return 1
    steps = plan.get("steps") or []
    execution = {"status": "succeeded", "steps": []}
    for step in steps:
        step_name = step.get("name") or "step"
        commands = step.get("commands") or []
        step_record = {"name": step_name, "commands": []}
        for command in commands:
            started_at = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
            result = subprocess.run(command, shell=True, capture_output=True, text=True)
            finished_at = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
            command_record = {
                "command": command,
                "status": "succeeded" if result.returncode == 0 else "failed",
                "exit_code": result.returncode,
                "started_at": started_at,
                "finished_at": finished_at,
                "stdout": result.stdout[-4000:],
                "stderr": result.stderr[-4000:],
            }
            step_record["commands"].append(command_record)
            if result.returncode != 0:
                execution["status"] = "failed"
                execution.setdefault("failed_command", command_record)
                execution["steps"].append(step_record)
                _write_deploy_execution(plan_path, execution)
                return result.returncode
        execution["steps"].append(step_record)
    _write_deploy_execution(plan_path, execution)
    return 0


def _write_deploy_execution(plan_path: Path, execution: dict) -> None:
    output_path = plan_path.parent / "deploy_execution.json"
    output_path.write_text(json.dumps(execution, indent=2))


def main() -> None:
    args = _parse_args(sys.argv)
    cmd = args["command"]
    env = build_runtime_env()
    seed_url = args["seed_url"] or str(env.get("XYN_SEED_URL", "")).strip() or "http://seed.localhost"

    if cmd == "preflight":
        sys.exit(0 if preflight(args["skip_ai_keys"]) else 1)
    if cmd == "stop":
        print_info("Stopping Xyn Seed platform...")
        subprocess.run(["docker", "compose", "down"], check=False)
        stopped_projects, failed_projects = _stop_provisioned_instances()
        if stopped_projects:
            print_info("Stopped provisioned sibling compose projects:")
            for project in stopped_projects:
                print_info(f"  - {project}")
        if failed_projects:
            print_warning("Some sibling projects could not be fully removed:")
            for row in failed_projects:
                print_warning(f"  - {row}")
        sys.exit(0)
    if cmd == "logs":
        subprocess.run(["docker", "compose", "logs", "-f"] + sys.argv[2:], check=False)
        sys.exit(0)
    if cmd == "status":
        sys.exit(status(seed_url))
    if cmd == "apply":
        if "--from" not in sys.argv:
            print_error("Missing --from <path>")
            sys.exit(1)
        idx = sys.argv.index("--from")
        if idx + 1 >= len(sys.argv):
            print_error("Missing path after --from")
            sys.exit(1)
        sys.exit(apply_release_plan(sys.argv[idx + 1]))
    if cmd == "provision":
        if len(sys.argv) < 3 or sys.argv[2] != "local":
            print_error("Usage: ./xynctl provision local [--name <name>] [--force] [--job-prompt <text>] [--repo-ref <path>]")
            sys.exit(1)
        if not preflight(args["skip_ai_keys"]):
            sys.exit(1)
        if not _wait_for_seed_health(seed_url, timeout_seconds=2):
            print_warning("Seed core does not appear healthy yet; starting core stack first...")
            if not start(detached=True, env=env):
                sys.exit(2)
            if not _wait_for_seed_health(seed_url, timeout_seconds=180, show_progress=True):
                print_error("Seed API is unavailable; cannot provision local instance")
                _print_seed_health_debug(seed_url)
                sys.exit(3)
        print_info("Resolving artifacts...")
        artifacts_ok, resolved = _resolve_artifacts_via_seed(seed_url, env)
        if not artifacts_ok:
            print_warning(f"Seed registry resolver failed; falling back to local env resolution: {resolved.get('error')}")
            artifacts_ok, fallback = _resolve_artifacts(env)
            resolved = {
                "registry_slug": str(env.get("XYN_ARTIFACT_REGISTRY_SLUG", "")).strip() or "env-fallback",
                "images": {
                    "ui_image": fallback.get("ui_image"),
                    "api_image": fallback.get("api_image"),
                    "channel": DEFAULT_IMAGE_TAG,
                },
            }
        if not artifacts_ok:
            sys.exit(4)
        images = resolved.get("images") if isinstance(resolved.get("images"), dict) else {}
        ok, payload = _provision_local(
            seed_url,
            name=args["name"],
            force=args["force"],
            job_prompt=args["job_prompt"],
            repo_ref=args["repo_ref"],
            ui_image=str(images.get("ui_image") or ""),
            api_image=str(images.get("api_image") or ""),
            registry_slug=str(resolved.get("registry_slug") or ""),
            channel=str(images.get("channel") or DEFAULT_IMAGE_TAG),
            workspace_slug=str(env.get("XYN_WORKSPACE_SLUG", "default")).strip() or "default",
        )
        if not ok:
            print_error(f"Provisioning failed: {payload.get('error')}")
            sys.exit(5)
        print_success(f"Provision status: {payload.get('status')}")
        if payload.get("ui_url"):
            print_success(f"Open: {payload.get('ui_url')}")
        print_info(json.dumps(payload, indent=2))
        sys.exit(0)
    if cmd in {"help", "--help", "-h"}:
        print("Xyn Seed Control Tool (xynctl)")
        print("\nUsage:")
        print("  ./xynctl preflight [--skip-ai-keys]")
        print("  ./xynctl start [--attach] [--provision] [--force] [--name <name>] [--job-prompt <text>] [--repo-ref <path>]")
        print("  ./xynctl quickstart [--force] [--name <name>]    # alias for start --provision")
        print("  ./xynctl provision local [--force] [--name <name>] [--job-prompt <text>] [--repo-ref <path>]")
        print("  ./xynctl status")
        print("  ./xynctl stop")
        print("  ./xynctl logs [service]")
        print("  ./xynctl apply --from <path>")
        sys.exit(0)
    if cmd and cmd not in {"start", "quickstart"}:
        print_error(f"Unknown command: {cmd}")
        print_info("Run './xynctl help' for usage.")
        sys.exit(1)

    # default: start
    provision = args["provision"] or cmd == "quickstart"
    if not preflight(args["skip_ai_keys"]):
        sys.exit(1)
    if provision:
        sys.exit(
            start_with_provision(
                env,
                force=args["force"],
                name=args["name"],
                job_prompt=args["job_prompt"],
                repo_ref=args["repo_ref"],
                seed_url=seed_url,
            )
        )
    detached = bool(args["non_interactive"]) or not bool(args["attach"])
    ok = start(detached=detached, env=env)
    if ok:
        print_info("Waiting for seed API health...")
        if _wait_for_seed_health(seed_url, timeout_seconds=180, show_progress=True):
            print_success(f"Seed API is healthy at {seed_url}")
        else:
            print_error(f"Seed API did not become healthy at {seed_url}")
            _print_seed_health_debug(seed_url)
            ok = False
    sys.exit(0 if ok else 2)


if __name__ == "__main__":
    main()
